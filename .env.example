# Example environment variables (fill with production/live values)
# Copy this to .env in development or set through your hosting provider for production.

NODE_ENV=production
PORT=4000
CLIENT_URL=https://your-frontend.example
FRONTEND_URL=https://your-frontend.example

# Database (example placeholders)
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT
JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_secret

# API base URLs
API_BASE_URL=https://your-api.example/api/v1
VITE_API_BASE_URL=https://your-api.example/api/v1

# Payments
RAZORPAY_KEY_ID=rzp_live_or_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Other important envs
S3_BUCKET_NAME=your_s3_bucket
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Notes:
# - Do NOT commit your real keys to source control.
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=photoapp_dev
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

JWT_ACCESS_SECRET=change_this_to_a_random_32_char_string
JWT_REFRESH_SECRET=change_this_to_a_different_32_char_string
GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_CLIENT_IDS=
VITE_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
CLOUDFRONT_DOMAIN=

EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# Security / Production hardening
ADMIN_EMAILS=
OWNER_EMAILS=
CORS_ORIGINS=
RATE_LIMIT_API_MAX=300
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_UPLOAD_MAX=60
LOG_LEVEL=info

# Image optimization / watermarking
IMAGE_JPEG_QUALITY=82
WATERMARK_ENABLED=false
WATERMARK_TEXT=EpixBox

# Notification toggles
ENABLE_UPLOAD_EMAIL_NOTIFICATIONS=false

# API docs / realtime
API_BASE_URL=http://localhost:4000/api/v1
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Payments
RAZORPAY_KEY_ID=rzp_test_or_live_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# CDN/cache strategy
PUBLIC_CACHE_MAX_AGE=300
PUBLIC_CACHE_S_MAX_AGE=1800
VITE_CLOUDFRONT_DOMAIN=

# Load test defaults
LOAD_TEST_BASE_URL=http://localhost:4000
LOAD_TEST_CONNECTIONS=30
LOAD_TEST_DURATION=15

# Sentry monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
ENABLE_SENTRY_TEST_ROUTE=false
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_LOGROCKET_APP_ID=
VITE_OWNER_EMAILS=

# API rate analytics
RATE_ANALYTICS_WINDOW_SIZE=1000
