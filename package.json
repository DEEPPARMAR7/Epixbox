{
  "name": "photoapp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "oneclick": "powershell -ExecutionPolicy Bypass -File ./start-all.ps1 -OpenCheckout",
    "oneclick:install": "powershell -ExecutionPolicy Bypass -File ./start-all.ps1 -InstallDeps -OpenCheckout",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
